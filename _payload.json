works","How It Works",[30,299,300,301,305],{},"The extension registers a custom language mode for ",[302,303,304],"code",{},".pseudo"," files and provides a built-in interpreter that parses and executes the code. Results are displayed in the VS Code output panel.",[25,307,309],{"id":308},"getting-started","Getting Started",[311,312,313,316,322,325],"ol",{},[41,314,315],{},"Install the extension from the VS Code Marketplace",[41,317,318,319,321],{},"Create a new file with the ",[302,320,304],{}," extension",[41,323,324],{},"Write your pseudo code",[41,326,327,328,331],{},"Press ",[302,329,330],{},"Ctrl+Shift+P"," and run \"Pseudo Runner: Execute\"",{"title":97,"searchDepth":98,"depth":98,"links":333},[334,335,336,337],{"id":27,"depth":98,"text":28},{"id":35,"depth":98,"text":36},{"id":296,"depth":98,"text":297},{"id":308,"depth":98,"text":309},"A VS Code extension that runs pseudo code files directly in the editor.","https://github.com/Kratosgado/pseudo-runner",[244,341],"https://image2url.com/r2/default/images/1772468076141-94683d8e-029b-4887-843f-99970e779057.png","https://marketplace.visualstudio.com/publishers/Kratosgado",{},{"icon":116},"/projects/pseudo-runner",{"title":258,"description":338},"pseudo-runner",[82,164],"projects/pseudo-runner","lEtu8O4bKLsBWbALyNK1YCvlh5bJNHejXalx8ZmAo5g",{"id":352,"title":353,"body":354,"coverImage":398,"description":399,"extension":105,"github":400,"images":401,"liveUrl":97,"meta":403,"navigation":404,"path":405,"rank":406,"seo":407,"slug":408,"stack":409,"stem":411,"__hash__":412},"projects/projects/autoscroll-web-extension.md","AutoScroll Web Extension",{"type":22,"value":355,"toc":393},[356,358,361,363,377,379],[25,357,28],{"id":27},[30,359,360],{},"AutoScroll Web Extension is a project that automatically scrolls the page for you.",[25,362,36],{"id":35},[38,364,365,371],{},[41,366,367,370],{},[44,368,369],{},"Automated Scrolling",": Hand-free scrolling experience.",[41,372,373,376],{},[44,374,375],{},"Configurable",": Settin