er-linux",[324,320],"https://image2url.com/r2/default/images/1772468211054-abb465e3-17e6-4220-b412-63a35671e73b.png","https://marketplace.visualstudio.com/items?itemName=KratosGado.nasm-compiler-linux",{},{"icon":116},"/projects/nasm-compiler-for-linux",{"title":263,"description":321},"nasm-compiler-for-linux",[301,307,313],"projects/nasm-compiler-for-linux","okvhZFVqpK0Wp4Km0pKNMtTZFCu1rzFOQP16pOCJrwA",{"id":335,"title":336,"body":337,"coverImage":381,"description":382,"extension":105,"github":383,"images":384,"liveUrl":97,"meta":385,"navigation":386,"path":387,"rank":98,"seo":388,"slug":389,"stack":390,"stem":391,"__hash__":392},"projects/projects/pseudo-code-interpreter.md","Pseudo Code Interpreter",{"type":22,"value":338,"toc":376},[339,341,344,346,366,368],[25,340,28],{"id":27},[30,342,343],{},"Pseudo Code Interpreter is a Rust-based tool that interprets and executes pseudo code files passed as command-line arguments. It allows developers to test their algorithms written in pseudo code.",[25,345,36],{"id":35},[38,347,348,354,360],{},[41,349,350,353],{},[44,351,352],{},"Command-Line Interface",": Run pseudo code files from the terminal.",[41,355,356,359],{},[44,357,358],{},"Interpretation",": Executes pseudo code syntax.",[41,361,362,365],{},[44,363,364],{},"Error Handling",": Provides feedback on invalid syntax.",[25,367,63],{"id":62},[38,369,370],{},[41,371,372,375],{},[44,373,374],{},"Rust",": A systems programming language that runs blazingly fast, prevents segfaults, and guarantees thread safety.",{"title":97,"searchDepth":98,"depth":98,"links":377},[378,379,380],{"id":27,"depth":98,"text":28},{"id":35,"depth":98,"text":36},{"id":62,"depth":98,"text":63},"https://lh3.googleusercontent.com/d/16349CIC6DYXDHTwt75gVh1bworLk95VZ","A pseudo code interpreter written in rust that interprets pseudocode file passed to it as cli argument.","https://github.com/Kratosgado/pseudo_interpreter",[],{},{"icon":116},"/projects/pseudo-code-interpreter",{"title":336,"descriptio